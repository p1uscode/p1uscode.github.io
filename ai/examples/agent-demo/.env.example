# agent-demo 専用設定（ルートの .env を上書きする形で mise が読み込む）

# バックエンド切り替え: litellm | ollama
AGENT_BACKEND=litellm

# モデル (BACKEND のデフォルトを上書きしたいときだけ指定)
#   litellm デフォルト: claude-sonnet-4-6
#   ollama  デフォルト: llama3.1:8b
# AGENT_MODEL=claude-sonnet-4-6
# AGENT_MODEL=qwen3.5:35b

# 使うツールをカンマ区切りで選択 (未指定=全ツール)
#   利用可能: search, fetch_url, wikipedia, now, calc, random_int
# AGENT_TOOLS=search,now,calc

# baseURL / 検索 URL (BACKEND のプリセットを使わず直接上書きしたいとき)
# LLM_BASE_URL=http://litellm.home.arpa/v1
# SEARXNG_BASE_URL=http://searxng.home.arpa
# AGENT_LANGFUSE_HOST=http://langfuse.home.arpa
