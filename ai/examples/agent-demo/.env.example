# agent-demo 専用設定（ルートの .env を上書きする形で mise が読み込む）

# モデル (LiteLLM の model_list に登録されたエイリアスを指定)
#   デフォルト: ollama/qwen3.5:9b (ホスト側 Ollama を LiteLLM 経由で叩く)
#   クラウド: claude-sonnet-4-6 / gpt-5.4 / gemini-2.5-flash ...
#   他のローカル: ollama/<tag> (例: ollama/llama3.3:70b)
# AGENT_MODEL=ollama/qwen3.5:9b
# AGENT_MODEL=claude-sonnet-4-6

# 使うツールをカンマ区切りで選択 (未指定=全ツール)
#   利用可能: search, fetch_url, wikipedia, now, calc, random_int
# AGENT_TOOLS=search,now,calc

# LiteLLM エンドポイント / 検索 URL (プリセットを上書きしたいとき)
# LLM_BASE_URL=http://litellm.home.arpa/v1
# SEARXNG_BASE_URL=http://searxng.home.arpa
# AGENT_LANGFUSE_HOST=http://langfuse.home.arpa
